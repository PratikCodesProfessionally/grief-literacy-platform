# Frontend environment (Vite)
# Copy to client/.env.local (never commit client/.env.local)

# Use backend AI proxy (recommended: keeps API keys server-side)
VITE_USE_BACKEND_AI_PROXY=true

# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional app config
VITE_APP_URL=http://localhost:5173

# If you disable the backend AI proxy, you'd need browser-exposed keys here.
# Not recommended:
# VITE_GEMINI_API_KEY=...
# VITE_HUGGINGFACE_API_KEY=...
# VITE_ANTHROPIC_API_KEY=...
