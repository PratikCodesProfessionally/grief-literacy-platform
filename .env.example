# AI Service Configuration
# Security note: by default the frontend uses a backend proxy so API keys stay server-side.

# Enable/disable backend AI proxy usage from the frontend (no secrets in browser)
VITE_USE_BACKEND_AI_PROXY=true

# Server-side API keys (RECOMMENDED)
# Hugging Face (FREE)
HUGGINGFACE_API_KEY=hf_your_token_here

# Google Gemini (FREE TIER available)
GEMINI_API_KEY=your_key_here

# Anthropic Claude (PAID)
# ANTHROPIC_API_KEY=sk-ant-api03-your_key_here

# Supabase Configuration (FREE - 500MB storage)
# Get your project credentials from: https://app.supabase.com
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# App Configuration
VITE_APP_URL=http://localhost:5173
VITE_ENABLE_ENCRYPTION=true
VITE_SYNC_INTERVAL_MINUTES=10

# Note: Copy this file to .env.local and add your actual API keys
# Never commit your actual .env.local file to version control

